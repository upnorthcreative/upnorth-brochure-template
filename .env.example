# ─────────────────────────────────────────────────────────────────────────────
# Environment variables for the Up North Creative brochure template
#
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local
#
# Never commit .env.local — it is already in .gitignore
# ─────────────────────────────────────────────────────────────────────────────

# ── Site ─────────────────────────────────────────────────────────────────────
# Public URL of the deployed site (no trailing slash).
# Used for sitemaps, og:url, and JSON-LD structured data.
NEXT_PUBLIC_SITE_URL=https://yoursite.com

# ── Resend (contact form email delivery) ─────────────────────────────────────
# Get your API key at resend.com → API Keys
# The sending domain (contactForm.fromEmail in lib/content.ts) must be
# verified in your Resend account before emails will deliver.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# ── Cloudflare Turnstile (spam protection) ───────────────────────────────────
# Get keys at dash.cloudflare.com → Turnstile → Add Site
# Use the test keys locally:
#   Site key:   1x00000000000000000000AA
#   Secret key: 1x0000000000000000000000000000000AA
# Leave blank to disable Turnstile (form still works — honeypot + rate limiting remain active).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ── Analytics ─────────────────────────────────────────────────────────────────
# Analytics IDs (GA4, GTM, Meta Pixel, Microsoft Clarity) are set directly in
# lib/content.ts under siteConfig.analytics — no environment variable needed.
